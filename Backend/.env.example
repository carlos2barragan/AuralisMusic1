
# Base de datos
MONGODB_URI_LOCAL=mongodb://localhost:27017/auralismusic
MONGODB_URI_PROD=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# URLs del backend
BACKEND_URL_LOCAL=http://localhost:3000
BACKEND_URL_PROD=https://<tu-dominio-backend>

# URLs del frontend
FRONTEND_URL_LOCAL=http://localhost:4200
FRONTEND_URL_PROD=https://<tu-dominio-frontend>

# JWT
JWT_SECRET=<clave_secreta_aleatoria>

# Configuracion del servidor
PORT=3000

# Email
MAIL_SERVICE=gmail
MAIL_USER=<tu_correo>@gmail.com
MAIL_PASS=<app_password_de_gmail>
SEEDER_USER_PASSWORD=<password_para_seeders>

# Cloudinary
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>
